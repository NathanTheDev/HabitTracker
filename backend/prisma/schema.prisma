// Switch provider to "postgresql" and update DATABASE_URL for production

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Habit {
  id          String            @id @default(cuid())
  userId      String            // SuperTokens user ID — no FK, ST owns user data
  name        String
  description String?
  frequency   String            @default("DAILY") // "DAILY" | "WEEKLY"
  quantity    Int               @default(1) // target count per day; 1 = simple boolean habit
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  completions HabitCompletion[]

  @@index([userId])
}

model HabitCompletion {
  id               String   @id @default(cuid())
  habitId          String
  habit            Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  completedAt      DateTime
  quantityProgress Int?     // tracks partial progress for quantity habits
  notes            String?
  createdAt        DateTime @default(now())

  @@unique([habitId, completedAt]) // one completion per habit per day
  @@index([habitId])
}

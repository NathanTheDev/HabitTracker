NODE_ENV=development
PORT=3001

# Set to your deployed frontend URL in production (e.g. https://app.yourdomain.com)
# The CORS policy is locked to this single origin — no wildcards.
FRONTEND_ORIGIN=http://localhost:3000

# --- Database ---
# Development (SQLite):
DATABASE_URL="file:./dev.db"
#
# Production (PostgreSQL):
# 1. In prisma/schema.prisma change provider from "sqlite" to "postgresql"
# 2. Set DATABASE_URL to your PostgreSQL connection string:
# DATABASE_URL="postgresql://user:password@host:5432/habittracker?schema=public"
# 3. Run: npx prisma migrate deploy

# --- SuperTokens (https://app.supertokens.com — free up to 5,000 MAUs) ---
# 1. Sign in at https://app.supertokens.com and create an app
# 2. Select "Passwordless" as the recipe
# 3. Copy the Connection URI and API key from the dashboard
SUPERTOKENS_CONNECTION_URI=https://<your-app>.aws.supertokens.io
SUPERTOKENS_API_KEY=<your-api-key>
